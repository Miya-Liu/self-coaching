{"openapi":"3.1.0","info":{"title":"Agentevals Webapp API","description":"\nHTTP API for the agentevals web dashboard.\n\n- **Suites** — list and inspect registered benchmark suites\n- **Runs** — create and poll evaluation runs\n- **Evolution** — self-evolution protocol runs and scorecards\n\nInteractive reference: `/docs` (Swagger UI) and `/redoc` (ReDoc).\nOpenAPI schema: `/openapi.json`.\n","version":"0.1.0"},"paths":{"/health":{"get":{"tags":["health"],"summary":"Health check","operationId":"health_health_get","responses":{"200":{"description":"Service is up","content":{"application/json":{"schema":{"additionalProperties":{"type":"string"},"type":"object","title":"Response Health Health Get"}}}}}}},"/api/suites":{"get":{"tags":["suites"],"summary":"List Suites","description":"Return all registered evaluation suites in summary form.","operationId":"list_suites_api_suites_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"items":{"$ref":"#/components/schemas/SuiteSummary"},"type":"array","title":"Response List Suites Api Suites Get"}}}}}}},"/api/suites/{suite_id}":{"get":{"tags":["suites"],"summary":"Get Suite","description":"Return details for a single suite, or 404 if it does not exist.","operationId":"get_suite_api_suites__suite_id__get","parameters":[{"name":"suite_id","in":"path","required":true,"schema":{"type":"string","title":"Suite Id"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/SuiteDetail"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/runs":{"post":{"tags":["runs"],"summary":"Create Run","description":"Create a new evaluation run and schedule it for background execution.\n\nThe returned summary can be used to poll `GET /api/runs/{id}` for status\nand metrics once the run completes.","operationId":"create_run_api_runs_p
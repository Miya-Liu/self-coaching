# AgentEvals-only live profile (local service at :8080)
# ---------------------------------------------------------------------------
# Copy to scenarios/demo.env (gitignored) for holdout / eval against real AgentEvals:
#   cp scenarios/demo.agentevals.env.example scenarios/demo.env
#
# Other services (self-learning, self-play, AERL) stay on in-process mocks until M2+.
# ---------------------------------------------------------------------------

LOOP_SERVICE_MODE=live
LOOP_AGENT_ID=6ed953f5-ca52-45ff-a137-9d2d1b2e1d8d
AGENT_ID=6ed953f5-ca52-45ff-a137-9d2d1b2e1d8d
LOOP_HOLDOUT_TIMEOUT_S=300
LOOP_TAU_FAIL=0.75
LOOP_SIGMA_MIN=3
LOOP_SIGMA_PLAY=0
LOOP_BATCH_SIZE=4
LOOP_IDLE_AFTER=0

ORCHESTRATOR_EVAL_BACKEND=agentevals
ORCHESTRATOR_TRAIN_BACKEND=mock
ORCHESTRATOR_TRANSPORT=module

AGENTEVALS_BASE_URL=http://localhost:8080
AGENTEVALS_SUITE_ID=MemoryArena_Preview
AGENTEVALS_SUITE_ID_HOLDOUT=MemoryArena_Preview
AGENTEVALS_POLL_INTERVAL_S=5
AGENTEVALS_TIMEOUT_S=3600

# Required for MemoryArena harness (RunCreate.agent_config.model.name)
AGENTEVALS_MODEL_NAME=gpt-4o

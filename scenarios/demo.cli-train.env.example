# Self-coaching loop — CLI training (db_bridge) staging profile
# ---------------------------------------------------------------------------
# Copy credentials locally (do not commit secrets):
#   cp scenarios/demo.cli-train.env.example scenarios/demo.cli-train.env
#   # merge Supabase keys from services/LoRA/db_bridge/.env
#
# Quick probe (no full training):
#   python scripts/cli_train_smoke.py --env-file scenarios/demo.cli-train.env --probe
#
# Full training dispatch (long-running):
#   python scripts/cli_train_smoke.py --env-file scenarios/demo.cli-train.env
#
# Design: docs/project/cli-training-implementation.md
# AReaL marker request: docs/design/integrations/areal_cli_training_request.md
# ---------------------------------------------------------------------------

LOOP_SERVICE_MODE=live
ORCHESTRATOR_EVAL_BACKEND=mock
ORCHESTRATOR_LEARN_BACKEND=mock
ORCHESTRATOR_SELFPLAY_BACKEND=mock
ORCHESTRATOR_TRAIN_BACKEND=cli

# Shared Supabase (same as db_bridge)
# SUPABASE_URL=http://82.157.184.89:54321
# SUPABASE_SERVICE_ROLE_KEY=...
# BRIDGE_USER_ID=...

# Remote training command (paths on AReaL GPU host)
CLI_TRAIN_CWD=/dfs/share-groups/letrain/zhoujie/AReaL-main
CLI_TRAIN_SCRIPT=customized_areal/tpfc/scripts/train_tpfc_tree_search.py
CLI_TRAIN_CONFIG=customized_areal/tpfc/configs/config_tpfc_Qwen3-5L-9B_tree_search_self_play.yaml
CLI_TRAIN_TIMEOUT=3600
CLI_TRAIN_POLL_INTERVAL=5
CLI_TRAIN_TMUX_PREFIX=train-
AERL_TIMEOUT_S=3600

# Optional per-pipeline override:
# CLI_TRAIN_CONFIG_GRPO_QWEN3_8B=customized_areal/tpfc/configs/config_grpo.yaml

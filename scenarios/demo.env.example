# Self-coaching loop demo — service profile template
# ---------------------------------------------------------------------------
# Copy to scenarios/demo.env (local only; do not commit secrets):
#   cp scenarios/demo.env.example scenarios/demo.env
#
# Usage:
#   python scripts/mock_self_coaching_demo.py --env-file scenarios/demo.env
#   (auto-loads scenarios/demo.env when that file exists)
#
# Design: docs/project/mock-to-real-migration.md
# ---------------------------------------------------------------------------

# --- Service mode (authoritative) ------------------------------------------
# mock-module  = in-process mock engines (default; fastest; CI uses this)
# mock-http    = HTTP to local mock stack (127.0.0.1 ports below)
# live         = staging/production URLs; set ORCHESTRATOR_*_BACKEND below
LOOP_SERVICE_MODE=mock-module

# --- Loop thresholds (demo / full_loop.json) -------------------------------
LOOP_AGENT_ID=demo-agent
LOOP_TAU_FAIL=0.75
LOOP_SIGMA_MIN=3
LOOP_SIGMA_PLAY=0
LOOP_BATCH_SIZE=4
LOOP_IDLE_AFTER=0

# Holdout eval wait budget (seconds). Mock: short. Live: 300–600.
LOOP_HOLDOUT_TIMEOUT_S=5

# --- Orchestrator backends (live mode) -------------------------------------
# mock       = use mock eval/train/learn shaping inside composite client
# agentevals = real AgentEvals for suite / holdout eval
# aerl       = real AERL for training
# self-learning = real self-learning service for learn/evolve
ORCHESTRATOR_EVAL_BACKEND=mock
ORCHESTRATOR_TRAIN_BACKEND=mock
ORCHESTRATOR_LEARN_BACKEND=mock
ORCHESTRATOR_TRANSPORT=module
# ORCHESTRATOR_BASE_URL=http://127.0.0.1:8765

# --- AgentEvals ------------------------------------------------------------
# Unset = in-process MockAgentEvalsEngine (mock-module)
# AGENTEVALS_BASE_URL=http://127.0.0.1:8080
# MOCK_AGENTEVALS_URL=http://127.0.0.1:8080
AGENTEVALS_SUITE_ID=tool-use-canary
AGENTEVALS_SUITE_ID_HOLDOUT=tool-use-holdout
# AGENTEVALS_POLL_INTERVAL_S=5
# AGENTEVALS_TIMEOUT_S=3600
# AGENTEVALS_API_KEY=

# --- Self-learning ---------------------------------------------------------
# Unset = in-process MockSelfLearningEngine
# SELF_LEARNING_BASE_URL=http://127.0.0.1:8766
# MOCK_SELF_LEARNING_URL=http://127.0.0.1:8766
# MOCK_SELF_LEARNING_PORT=38766

# --- Self-play (C06 generate-suite / C07 generate — distinct endpoints) ---
# Pipeline service (live): docs/project/self-play-pipeline-implementation.md
# mock       = in-process MockSelfPlayEngine or MOCK_SELF_PLAY_URL HTTP
# pipeline   = Self-Questioning Pipeline Service (proceed signal only)
# ORCHESTRATOR_SELFPLAY_BACKEND=mock
# ORCHESTRATOR_SELFPLAY_BACKEND=pipeline
# PIPELINE_SERVICE_URL=http://10.110.158.146:8001
# PIPELINE_POLL_INTERVAL_S=5
# PIPELINE_POLL_TIMEOUT_S=3600
# PIPELINE_BATCH_TRAIN_EVAL_FLAG=train
# PIPELINE_TRAIN_EVAL_FLAG=eval
# PIPELINE_DRY_RUN=0
# Unset = in-process MockSelfPlayEngine
# MOCK_SELF_PLAY_URL=http://127.0.0.1:8767
# MOCK_SELF_PLAY_PORT=38767

# --- AERL / training -------------------------------------------------------
# Unset = in-process mock_aerl. TRAINER_BASE_URL also used by pipeline scripts.
# mock-http mode auto-sets MOCK_AERL_URL + ORCHESTRATOR_TRAIN_BACKEND=aerl.
# MOCK_AERL_URL=http://127.0.0.1:8004
# TRAINER_BASE_URL=http://127.0.0.1:8004
# TRAINER_API_KEY=
# AERL_POLL_INTERVAL_S=2
# AERL_TIMEOUT_S=3600

# --- Loop train adapter (M4.2+) --------------------------------------------
# LOOP_TRAIN_WAIT=true
# LOOP_TRAIN_AGENT_SNAPSHOT=true
# LOOP_TRAIN_REGISTRY_VERSION_ID=ver-prod-42
# LOOP_TRAIN_SKILL_BUNDLE_VERSION=skills-demo
# LOOP_TRAIN_ROLLOUT_CONFIG=scenarios/rollout-grpo.example.json
# LOOP_TRAIN_REWARD_SPEC={"schema_version":"reward.ic.v1","primary":"scalar"}
# LOOP_TRAIN_SOURCE=loop-t-path

# --- Auth (optional local; usually required on staging) --------------------
# MOCK_SERVICE_TOKEN=
# Used by coaching HTTP facade and some mock HTTP services.

# --- Auto-start local mock stack (mock-http mode only) -----------------------
# When LOOP_SERVICE_MODE=mock-http and URLs point at localhost, the demo may
# spawn mock services. Set 0 if you already run mock-stack-up.sh yourself.
# LOOP_AUTO_START_MOCK_STACK=1

# --- Staging example (LOOP_SERVICE_MODE=live) ------------------------------
# AgentEvals-only local profile: scenarios/demo.agentevals.env.example
# Uncomment and fill when running against real integrations (M1+):
#
# LOOP_SERVICE_MODE=live
# LOOP_HOLDOUT_TIMEOUT_S=300
# ORCHESTRATOR_EVAL_BACKEND=agentevals
# ORCHESTRATOR_TRAIN_BACKEND=aerl
# AGENTEVALS_BASE_URL=http://localhost:8080
# AGENTEVALS_SUITE_ID=MemoryArena_Preview
# AGENTEVALS_SUITE_ID_HOLDOUT=MemoryArena_Preview
# AGENTEVALS_MODEL_NAME=gpt-4o
# LOOP_AGENT_ID=6ed953f5-ca52-45ff-a137-9d2d1b2e1d8d
# AGENTEVALS_BASE_URL=https://agentevals.staging.example
# MOCK_SELF_LEARNING_URL=https://self-learning.staging.example
# MOCK_SELF_PLAY_URL=https://self-play.staging.example
# TRAINER_BASE_URL=https://aerl.staging.example
# MOCK_AERL_URL=https://aerl.staging.example
# AGENTEVALS_API_KEY=...
# TRAINER_API_KEY=...

# Unified live profile — Track 1 evolution loop (AgentEvals + Pipeline + CLI train)
# ---------------------------------------------------------------------------
# Copy locally (gitignored):
#   cp scenarios/demo.live.env.example scenarios/demo.live.env
#
# Preflight only (~30s):
#   python scripts/evolution_loop_clock_smoke.py --env-file scenarios/demo.live.env --phase preflight
#
# Safe integrated dry run (pipeline dry_run + mock train, or --probe-cli):
#   python scripts/evolution_loop_clock_smoke.py --env-file scenarios/demo.live.env --dry-run --probe-cli
#
# Full live tick (long — real pipeline jobs + CLI train + AgentEvals holdout):
#   python scripts/evolution_loop_clock_smoke.py --env-file scenarios/demo.live.env
#
# Align LOOP_AGENT_ID / AGENTEVALS_* with your AgentEvals registry registration.
# Learn backend stays mock until production self-learning staging (M2.4).
# ---------------------------------------------------------------------------

LOOP_SERVICE_MODE=live
LOOP_AGENT_ID=evolution-loop-agent
AGENT_ID=evolution-loop-agent
LOOP_HOLDOUT_TIMEOUT_S=300

# --- Backend selection (Track 1: three real + mock learn) ---
ORCHESTRATOR_EVAL_BACKEND=agentevals
ORCHESTRATOR_LEARN_BACKEND=mock
ORCHESTRATOR_SELFPLAY_BACKEND=pipeline
ORCHESTRATOR_TRAIN_BACKEND=cli
ORCHESTRATOR_TRANSPORT=module

# --- AgentEvals (holdout gate) ---
AGENTEVALS_BASE_URL=http://localhost:8080
AGENTEVALS_SUITE_ID=tool-use-canary
AGENTEVALS_SUITE_ID_HOLDOUT=tool-use-holdout
AGENTEVALS_POLL_INTERVAL_S=5
AGENTEVALS_TIMEOUT_S=3600
AGENTEVALS_MODEL_NAME=gpt-4o

# --- Self-play: Pipeline Service ---
PIPELINE_SERVICE_URL=http://10.110.158.146:8001
PIPELINE_POLL_INTERVAL_S=5
PIPELINE_POLL_TIMEOUT_S=3600
PIPELINE_BATCH_TRAIN_EVAL_FLAG=train
PIPELINE_TRAIN_EVAL_FLAG=eval

# --- Self-tuning: CLI train via db_bridge ---
SUPABASE_URL=http://<supabase-host>:54321
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>
BRIDGE_USER_ID=<your-bridge-user-id>

CLI_TRAIN_CWD=/dfs/share-groups/letrain/zhoujie/AReaL-main
CLI_TRAIN_SCRIPT=customized_areal/tpfc/scripts/train_tpfc_tree_search.py
CLI_TRAIN_CONFIG=customized_areal/tpfc/configs/config_tpfc_Qwen3-5L-9B_tree_search_self_play.yaml
CLI_TRAIN_TIMEOUT=3600
CLI_TRAIN_POLL_INTERVAL=5
CLI_TRAIN_TMUX_PREFIX=train-
AERL_TIMEOUT_S=3600

# --- Loop parameters ---
LOOP_TAU_FAIL=0.75
LOOP_SIGMA_MIN=3
LOOP_SIGMA_PLAY=3
LOOP_BATCH_SIZE=4
LOOP_IDLE_AFTER=0
LOOP_TRAIN_WAIT=true
LOOP_TRAIN_AGENT_SNAPSHOT=true

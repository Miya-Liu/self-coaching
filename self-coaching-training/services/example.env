# Copy to training/services/.env (gitignored). Used by AERL runners (_lib.sh, run-pipeline.sh).
# Default trainer URL matches training/pipelines/registry.yaml `service.url` unless overridden.

# TRAINER_BASE_URL=http://localhost:8004
# TRAINER_API_KEY=

# Local trainer source tree when PIPELINE_MODE=local or aerl (see training/pipelines/_lib.sh).
# AERL_ROOT=/path/to/AERL

# Rollout / OpenAI-compatible inference (agent env during rollouts).
# OPENAI_BASE_URL=https://llm-access-api-endpoint/v1
# OPENAI_API_KEY=

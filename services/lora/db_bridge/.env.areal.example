# ---------------------------------------------------------------------------
# db_bridge environment — AReaL HOST
#
# Source this for BOTH bridge processes on the AReaL host:
#   python -m db_bridge.run_stub     --side areal
#   python -m db_bridge.run_executor --side areal
# ---------------------------------------------------------------------------

# Shared Supabase project (same project le-agent uses). Service-role key
# required: the bridge tables have RLS enabled with no policies.
SUPABASE_URL=http://82.157.184.89:54321
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# The AReaL executor forwards /rl/* and /chat/completions to the REAL local
# AReaL proxy gateway.
BRIDGE_GATEWAY_UPSTREAM_URL=http://127.0.0.1:8080

# The le-agent-API stub (serving /api/agent/start and /api/agent/start-branch)
# listens here.
BRIDGE_LEAGENT_STUB_PORT=9101
BRIDGE_STUB_HOST=127.0.0.1

BRIDGE_POLL_INTERVAL=0.075

# Optional per-process user scope. If unset, callers must send X-Bridge-User-Id.
# BRIDGE_USER_ID=00000000-0000-0000-0000-000000000000

# Periodic executor cleanup for terminal bridge rows. Set interval to 0 to disable.
BRIDGE_CLEANUP_INTERVAL=300
BRIDGE_ROW_RETENTION_SECONDS=86400
BRIDGE_CLEANUP_BATCH_LIMIT=1000
BRIDGE_TIMEOUT_AGENT_START=300

# ---------------------------------------------------------------------------
# AReaL remote shell runner (optional, trusted-host, feature-flagged).
# Source the same Supabase credentials above, then run:
#   AREAL_REMOTE_SHELL_ENABLED=true uv run python -m db_bridge.run_shell_runner
#
# This executes ARBITRARY host shell code for authorized le-agent callers. It is
# NOT a sandbox. Enable it only where this host is intentionally trusted.
# Requires `tmux` installed on the host. Disabled by default.
# ---------------------------------------------------------------------------
AREAL_REMOTE_SHELL_ENABLED=true
AREAL_REMOTE_SHELL_RUNNER_ID=areal-box-1
AREAL_REMOTE_SHELL_POLL_INTERVAL=1.0
AREAL_REMOTE_SHELL_LEASE_SECONDS=60
AREAL_REMOTE_SHELL_SWEEP_INTERVAL=30
AREAL_REMOTE_SHELL_DEFAULT_TIMEOUT=300
AREAL_REMOTE_SHELL_MAX_TIMEOUT=3600
AREAL_REMOTE_SHELL_MAX_LOG_BYTES=65536
AREAL_REMOTE_SHELL_MAX_CONCURRENCY=4
AREAL_REMOTE_SHELL_DEFAULT_CWD=/root/AReaL
AREAL_REMOTE_SHELL_SESSION_PREFIX=areal_
AREAL_REMOTE_SHELL_WORK_DIR=/tmp/areal_remote_shell
AREAL_REMOTE_SHELL_TMUX_BIN=tmux
AREAL_REMOTE_SHELL_CLEANUP_INTERVAL=300
AREAL_REMOTE_SHELL_RETENTION_SECONDS=604800

# ---------------------------------------------------------------------------
# Set this for AReaL's backend_run (customized_areal/tpfc/backend_run.py) —
# NOT the bridge. Point the le-agent API at the local le-agent-API stub:
#
#   LE_AGENT_API_URL=http://127.0.0.1:9101
#
# backend_run still reads run status from the shared Supabase tables
# (agent_runs / tasks), which covers the intentionally-dropped SSE stream.
# ---------------------------------------------------------------------------

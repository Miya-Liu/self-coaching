# ---------------------------------------------------------------------------
# db_bridge environment — LE-AGENT HOST
#
# Source this for BOTH bridge processes on the le-agent host:
#   python -m db_bridge.run_stub     --side leagent
#   python -m db_bridge.run_executor --side leagent
# ---------------------------------------------------------------------------

# Shared Supabase project (same project AReaL uses). Service-role key required:
# the bridge tables have RLS enabled with no policies.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# The le-agent executor forwards /api/agent/* to the REAL local le-agent API.
BRIDGE_LEAGENT_UPSTREAM_URL=http://127.0.0.1:8000

# The gateway stub (serving /rl/* and /chat/completions) listens here.
BRIDGE_GATEWAY_STUB_PORT=9100
BRIDGE_STUB_HOST=127.0.0.1

# Aggressive polling + generous LLM timeout (seconds).
BRIDGE_POLL_INTERVAL=0.075

# Optional per-process user scope. If unset, callers must send X-Bridge-User-Id.
# BRIDGE_USER_ID=00000000-0000-0000-0000-000000000000

# Periodic executor cleanup for terminal bridge rows. Set interval to 0 to disable.
BRIDGE_CLEANUP_INTERVAL=300
BRIDGE_ROW_RETENTION_SECONDS=86400
BRIDGE_CLEANUP_BATCH_LIMIT=1000
BRIDGE_TIMEOUT_CHAT_COMPLETIONS=180

# ---------------------------------------------------------------------------
# Set this on the le-agent APPLICATION (api.py / worker) — NOT the bridge.
# Point the AReaL proxy gateway at the local gateway stub. This single value
# is also returned to the agent as the LLM proxy_base_url, so chat/completions
# is routed through the bridge automatically.
#
#   AREAL_PROXY_GATEWAY_URL=http://127.0.0.1:9100
#   AREAL_ONLINE_TRAINING_ENABLED=true
# ---------------------------------------------------------------------------
